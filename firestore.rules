rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /schedules/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /parcels/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /finances/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
